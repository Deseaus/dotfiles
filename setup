#!/bin/sh

# Original script from https://github.com/aharris88/dotfiles
# This script creates symlinks from the home directory to any desired dotfiles in ~/dotfiles


dir=~/dotfiles                    # dotfiles directory
backupdir=~/dotfiles_backup          # old dotfiles backup directory

# Files/dirs to symlink to ~
homefiles="gitconfig gitignore_global agignore vim vimrc basicvimrc nvim nvimrc tmux tmux.conf zshrc zsh_plugins.txt zsh_plugins_pre.txt"
configfiles="htoprc"

echo "==================="
echo "Installing dotfiles"
echo "==================="
echo " "
echo "1. Creating $backupdir to backup any existing dotfiles in ~ ..."
mkdir -p $backupdir
mkdir -p ~/dotfiles_old/config

# Change to the dotfiles directory
cd $dir

for file in $homefiles; do
    echo " "
    echo "[BACKUP] Moving $file from ~ to $backupdir/config ..."
    mv ~/.$file ~/dotfiles_old/
    ln -s $dir/$file ~/.$file
    echo "[LINKED] $file"
done


for file in $configfiles; do
    echo " "
    echo "[BACKUP] Moving $file from ~ to $backupdir/config ..."
    mv ~/.$file ~/dotfiles_old/config
    ln -s $dir/$file ~/.config/$file
    echo "[LINKED] $file"
done

# Modern Neovim config (lazy.nvim-based; see nvim-config/init.lua).
# Separate from the legacy `nvim`/`nvimrc` entries above since Neovim only
# reads ~/.config/nvim/init.lua, not ~/.nvimrc.
echo " "
echo "[BACKUP] Moving nvim config from ~/.config/nvim to $backupdir/config ..."
mv ~/.config/nvim ~/dotfiles_old/config/nvim
ln -s $dir/nvim-config ~/.config/nvim
echo "[LINKED] nvim-config -> ~/.config/nvim"


# ===============
# Installers
# ===============

install_vim_plug () {
    # Get the latest version from GitHub
    # Then open vim and :PlugInstall
    curl -fLo ~/.vim/autoload/plug.vim --create-dirs https://raw.githubusercontent.com/junegunn/vim-plug/master/plug.vim
    echo "[INSTALLED] vimplug"
}

install_antidote () {
    # Antidote: manage zsh plugins
    git clone --depth=1 https://github.com/mattmc3/antidote.git ~/.antidote
    echo "[INSTALLED] antidote"
}

install_tpm () {
    # tmux Package manager
    git clone https://github.com/tmux-plugins/tpm ~/.tmux/plugins/tpm
    echo "[INSTALLED] tpm (tmux plugin manager)"
}

install_vim_plug
install_antidote
install_tpm
